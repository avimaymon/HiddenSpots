generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// NextAuth models
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Preferences
  locale         String          @default("he")
  mapProvider    MapProviderType @default(MAPBOX)
  mapStyle       String          @default("outdoors-v12")
  theme          String          @default("system")
  defaultPrivacy PrivacyLevel    @default(PRIVATE)
  passwordHash   String?
  onboarded      Boolean         @default(false)

  accounts      Account[]
  sessions      Session[]
  locations     Location[]
  categories    Category[]
  tags          Tag[]
  collections   Collection[]
  trips         Trip[]
  visits        Visit[]
  smartViews    SmartView[]
  sharedBy      Share[]    @relation("SharedBy")
  sharedWith    Share[]    @relation("SharedWith")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Location
// ─────────────────────────────────────────────

model Location {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core
  title       String
  description String? @db.Text
  slug        String?

  // Coordinates
  latitude  Float
  longitude Float
  altitude  Float?
  address   String?
  country   String?
  region    String?

  // Classification
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  tags       TagOnLocation[]

  // Status flags
  isFavorite    Boolean   @default(false)
  isBucketList  Boolean   @default(false)
  isVisited     Boolean   @default(false)
  visitCount    Int       @default(0)
  lastVisitedAt DateTime?

  // Physical details
  difficulty       DifficultyLevel?
  accessibility    String?
  hasParking       Boolean?
  hasWater         Boolean?
  hasShade         Boolean?
  cellularQuality  CellularQuality?
  isFamilyFriendly Boolean?
  isDogFriendly    Boolean?
  isCampingAllowed Boolean?

  // Timing
  recommendedSeasons String[]
  recommendedHours   String?
  bestTimeToVisit    String?

  // Extra
  privateNotes String?   @db.Text
  externalLinks String[]
  coverPhotoUrl String?

  // Privacy
  privacy          PrivacyLevel @default(PRIVATE)
  fuzzyCoordinates Boolean      @default(false)
  fuzzyRadiusMeters Int         @default(500)

  // Relations
  photos          LocationPhoto[]
  visits          Visit[]
  collectionItems CollectionLocation[]
  tripLocations   TripLocation[]
  shares          Share[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([latitude, longitude])
  @@index([userId, isFavorite])
  @@index([userId, isBucketList])
  @@index([userId, categoryId])
}

model LocationPhoto {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  url       String
  blobKey   String?
  caption   String?
  isPrimary Boolean  @default(false)
  width     Int?
  height    Int?
  takenAt   DateTime?

  createdAt DateTime @default(now())

  @@index([locationId])
}

// ─────────────────────────────────────────────
// Category & Tags
// ─────────────────────────────────────────────

model Category {
  id       String  @id @default(cuid())
  name     String
  icon     String  @default("map-pin")
  color    String  @default("#22c55e")
  isSystem Boolean @default(false)
  userId   String?
  user     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  locations Location[]

  createdAt DateTime @default(now())

  @@index([userId])
}

model Tag {
  id     String @id @default(cuid())
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  locations TagOnLocation[]

  createdAt DateTime @default(now())

  @@unique([name, userId])
  @@index([userId])
}

model TagOnLocation {
  locationId String
  tagId      String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([locationId, tagId])
}

// ─────────────────────────────────────────────
// Collections
// ─────────────────────────────────────────────

model Collection {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String       @default("#6366f1")
  icon        String       @default("folder")
  privacy     PrivacyLevel @default(PRIVATE)
  sortOrder   Int          @default(0)
  parentId    String?
  parent      Collection?  @relation("CollectionFolder", fields: [parentId], references: [id])
  children    Collection[] @relation("CollectionFolder")

  locations CollectionLocation[]
  shares    Share[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([parentId])
}

model SmartView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  filters   Json
  sortBy    String   @default("createdAt")
  icon      String   @default("sparkles")
  color     String   @default("#8b5cf6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CollectionLocation {
  collectionId String
  locationId   String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)
  addedAt      DateTime   @default(now())

  @@id([collectionId, locationId])
}

// ─────────────────────────────────────────────
// Visits
// ─────────────────────────────────────────────

model Visit {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  visitedAt DateTime
  rating    Int?     // 1-5
  notes     String?  @db.Text
  weather   String?
  duration  Int?     // minutes
  companions String[]

  photos VisitPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([locationId])
  @@index([userId, visitedAt])
}

model VisitPhoto {
  id      String @id @default(cuid())
  visitId String
  visit   Visit  @relation(fields: [visitId], references: [id], onDelete: Cascade)

  url       String
  blobKey   String?
  caption   String?
  takenAt   DateTime?

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// Trips
// ─────────────────────────────────────────────

model Trip {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  privacy     PrivacyLevel @default(PRIVATE)
  color       String       @default("#f59e0b")

  locations TripLocation[]
  shares    Share[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model TripLocation {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  sortOrder  Int      @default(0)
  notes      String?
  stayDuration Int?   // minutes planned at this stop

  createdAt DateTime @default(now())

  @@index([tripId])
}

// ─────────────────────────────────────────────
// Sharing
// ─────────────────────────────────────────────

model Share {
  id           String     @id @default(cuid())
  sharedById   String
  sharedBy     User       @relation("SharedBy", fields: [sharedById], references: [id])
  sharedWithId String?
  sharedWith   User?      @relation("SharedWith", fields: [sharedWithId], references: [id])

  locationId   String?
  location     Location?   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  tripId       String?
  trip         Trip?       @relation(fields: [tripId], references: [id], onDelete: Cascade)

  permission  Permission   @default(VIEW)
  publicToken String?      @unique @default(cuid())
  expiresAt   DateTime?
  viewCount   Int          @default(0)

  createdAt DateTime @default(now())

  @@index([sharedById])
  @@index([publicToken])
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum MapProviderType {
  MAPBOX
  GOOGLE
  LEAFLET
}

enum DifficultyLevel {
  EASY
  MODERATE
  HARD
  EXPERT
}

enum CellularQuality {
  NONE
  POOR
  FAIR
  GOOD
  EXCELLENT
}

enum PrivacyLevel {
  PRIVATE
  SHARED
  PUBLIC
  SECRET
}

enum Permission {
  VIEW
  COMMENT
  EDIT
  MANAGE
}
